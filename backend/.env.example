# Monday.com
MONDAY_TOKEN=your_monday_api_token

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=generate_a_64_char_hex_secret
REORDER_URL=https://medically-modern.github.io/reorder-patient-form

# RingCentral SMS
RC_SERVER_URL=https://platform.ringcentral.com
RC_CLIENT_ID=your_rc_client_id
RC_CLIENT_SECRET=your_rc_client_secret
RC_JWT=your_rc_jwt_token
RC_FROM_NUMBER=+13475037148

# AWS S3 (for insurance card uploads)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=mm-insurance-cards

# Admin
ADMIN_API_KEY=generate_a_secret_key

# Safety gate — set to true only when ready to send real texts
PRODUCTION_SMS_ENABLED=false
PRODUCTION_MODE=false

# Server
PORT=3001
